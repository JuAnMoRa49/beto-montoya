---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import GeneralLayout from "./GeneralLayout.astro"; // O tu layout base
import { Image } from "astro:assets";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, heroImage } = Astro.props;
---

<GeneralLayout>
  <article class="bg-white min-h-screen">
    <header
      class="relative h-[60vh] min-h-[400px] w-full bg-primary overflow-hidden"
    >
      {
        heroImage && (
          <Image
            src={heroImage}
            alt={title}
            class="absolute inset-0 w-full h-full object-cover opacity-60"
          />
        )
      }
      <div
        class="absolute inset-0 bg-gradient-to-t from-primary via-primary/20 to-transparent"
      >
      </div>

      <div class="absolute inset-0 flex flex-col justify-end pb-16 px-4">
        <div class="max-w-4xl mx-auto w-full">
          <div
            class="inline-block bg-secondary text-white text-xs font-black uppercase px-3 py-1 mb-6 tracking-widest"
          >
            Crónica Pro
          </div>
          <h1
            class="text-white text-4xl md:text-7xl font-black uppercase leading-none mb-4"
          >
            {title}
          </h1>
          <p
            class="text-gray-300 text-lg md:text-xl max-w-2xl italic font-light"
          >
            {description}
          </p>
          <div
            class="mt-8 flex items-center gap-4 text-white/60 font-bold uppercase text-xs tracking-widest"
          >
            <FormattedDate date={new Date(pubDate)} />
            <span class="w-8 h-[1px] bg-secondary"></span>
            <span>Por [Tu Nombre]</span>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-4xl mx-auto px-4 py-20">
      <div
        class="prose prose-lg md:prose-xl max-w-none
        prose-headings:text-primary prose-headings:uppercase prose-headings:font-black
        prose-p:text-gray prose-p:leading-relaxed prose-p:mb-8
        prose-strong:text-primary prose-strong:font-bold
        prose-blockquote:border-l-secondary prose-blockquote:bg-gray-50 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:italic
        prose-img:rounded-lg prose-img:shadow-xl"
      >
        <slot />
      </div>

      <footer class="mt-20 pt-10 border-t border-gray/20">
        <div
          class="flex flex-col md:flex-row justify-between items-center gap-6"
        >
          <div class="flex gap-2">
            <span
              class="px-3 py-1 bg-primary text-white text-[10px] font-bold uppercase"
              >Táctica</span
            >
            <span
              class="px-3 py-1 bg-primary text-white text-[10px] font-bold uppercase"
              >WPT</span
            >
          </div>
          <button
            onclick="history.back()"
            class="group flex items-center gap-3 text-primary font-black uppercase text-sm tracking-tighter"
          >
            <span class="group-hover:-translate-x-2 transition-transform"
              >←</span
            > Volver al Journal
          </button>
        </div>
      </footer>
    </div>
  </article>
</GeneralLayout>

<style is:global>
  /* Ajuste para que el texto de Markdown se vea perfecto */
  .prose p {
    color: #4b5563; /* Un gris oscuro legible */
    line-height: 1.8;
  }
</style>
