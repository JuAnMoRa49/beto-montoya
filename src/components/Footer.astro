---
const today = new Date();
import { NAVIGATION } from "../consts";
import { SOCIALS } from "../consts";
---

<footer class="flex flex-col left-0 right-0 bg-primary text-white py-8">
  <div
    class="general-padding w-full flex flex-col md:flex-row justify-between gap-8"
  >
    <div class="flex flex-col justify-between gap-8">
      <h2 class="text-4xl font-bold">Beto Montoya</h2>
      <form class="flex gap-4">
        <input
          class="border-b-2 px-4 py-2 h-min"
          type="email"
          placeholder="Ingresar tu correo"
        />
        <button
          class="bg-white text-primary hover:bg-white/80 py-2 px-4 rounded-md h-min"
          >Subscribe</button
        >
      </form>
    </div>
    <nav class="flex justify-between gap-24">
      <div>
        <p class="uppercase font-semibold text-white/40">Navagacion</p>
        <ul>
          {
            NAVIGATION.map((item) => (
              <li key={item.label}>
                <a href={item.url}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="text-right">
        <p class="uppercase font-semibold text-white/40">Sígueme</p>
        <ul>
          {
            SOCIALS.map((item) => (
              <li key={item.label}>
                <a href={item.url} target="_blank" rel="noopener noreferrer">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>
</footer>
