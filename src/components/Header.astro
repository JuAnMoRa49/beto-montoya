---
import { NAVIGATION } from "../consts";
---

<header class="fixed left-0 right-0 bg-primary text-white z-99 overflow-hidden">
  <div class="general-padding w-full flex justify-between items-center py-4">
    <a href="/" class="flex items-center">
      <img src="/favicon-white.svg" alt="Logo de Beto Montoya" class="size-8" />
      <h2 class="text-xl font-bold">Beto Montoya</h2>
    </a>
    <nav>
      <ul class="flex gap-8">
        {
          NAVIGATION.map((item) => (
            <li key={item.label}>
              <a href={item.url}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
